# ---------------------------------------------------------------------------
# Imperium Italian Textile — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Production env vars are configured in Vercel.
# ---------------------------------------------------------------------------

# Site URL — canonical production URL. Used for metadata, sitemap, robots, OG.
NEXT_PUBLIC_SITE_URL=https://imperiumitaliantextile.com

# Resend (contact form email delivery)
# When absent on localhost, the contact server action returns a mock success
# response and logs the payload to the console (see Phase 4 of the roadmap).
RESEND_API_KEY=
RESEND_FROM=hello@imperiumitaliantextile.com
RESEND_TO=

# WhatsApp Business number in international format, no "+", no spaces.
# Used by the WhatsApp CTA and the mobile fixed bar.
NEXT_PUBLIC_WHATSAPP_NUMBER=971544844082

# Plausible Analytics — domain configured in the Plausible dashboard.
# Leave empty to disable the analytics script (e.g. on localhost).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=imperiumitaliantextile.com

# Contact form honeypot — name of the hidden field, optional override.
# Defaults to "company_website" if unset.
HONEYPOT_FIELD=

# Search-engine indexing switch (PRD F-5). Leave unset everywhere until launch.
# At launch (Phase 6.B): set to "true" in the Vercel production environment ONLY.
NEXT_PUBLIC_ALLOW_INDEXING=

# Silk Hero kill switch (docs/superpowers/specs/2026-07-07-silk-hero-experience-design.md).
# Set to "off" to force the static poster everywhere, bypassing WebGL
# entirely (e.g. if the live shader misbehaves in production). Leave unset
# to run the normal poster/live decision tree.
NEXT_PUBLIC_SILK_HERO=